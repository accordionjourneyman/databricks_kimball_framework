# Copy this file to .env and fill in your Databricks workspace details.
# .env is git-ignored by default; never commit secrets.
#
# REQUIRED variables for running integration/golden tests remotely:
#   DATABRICKS_HOST   - Your Databricks workspace URL
#   DATABRICKS_TOKEN  - A Databricks personal access token
#
# Note: the variable name must be exactly DATABRICKS_TOKEN (not DATABRICKS_API_TOKEN).
# The Databricks SDK and the kimball-framework tooling both expect this name.

# Databricks workspace URL, e.g. https://myworkspace.cloud.databricks.com
DATABRICKS_HOST=https://<workspace>.cloud.databricks.com

# Personal access token with permissions to:
#   - run jobs
#   - read/write workspace files under /Workspace/Users/ci/kimball_framework
#   - create schemas and tables in KIMBALL_TEST_CATALOG
DATABRICKS_TOKEN=dapi...

# Optional: existing all-purpose (classic) cluster ID.
# Leave empty or unset to use serverless compute (default for Databricks Free Edition).
DATABRICKS_CLUSTER_ID=0123-456789-abcdef0

# Optional: catalog used by integration tests to create test schemas.
# Defaults to "spark_catalog" for local runs. Use "main" or your default catalog on Databricks.
KIMBALL_TEST_CATALOG=main
